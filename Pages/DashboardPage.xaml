<Page x:Class="Kazakov_KP_01._01.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1500"
      Title="DashboardPage" Background="Transparent">

    <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
        <StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 0 0 30">
                <Border Width="347" Height="192" BorderBrush="#FF33FFFF" BorderThickness="0.42" Background="#1A1C24" CornerRadius="15">
                    <StackPanel Margin="30">
                        <TextBlock Text="ВРЕМЯ РАБОТЫ" FontSize="18" Foreground="#6E7485" FontFamily="Exo 2"/>
                        <TextBlock Text="42ч 15м" FontSize="36" Margin="0 20 0 15" FontWeight="Bold" Foreground="#FFFFFF" FontFamily="Exo 2"/>
                        <TextBlock Text="Без перезагрузок" FontSize="18" FontWeight="SemiBold" Foreground="#00FFC2" FontFamily="Exo 2"/>
                    </StackPanel>
                </Border>

                <Border Width="347" Height="192" Margin="30 0 0 0" BorderBrush="#FF33FFFF" BorderThickness="0.42" Background="#1A1C24" CornerRadius="15">
                    <StackPanel Margin="30">
                        <TextBlock Text="ПОДПИСКА" FontSize="18" Foreground="#6E7485" FontFamily="Exo 2"/>
                        <TextBlock Text="12 ДНЕЙ" FontSize="36" Margin="0 20 0 15" FontWeight="Bold" Foreground="#00FFC2" FontFamily="Exo 2"/>
                        <TextBlock Text="Тариф: Ultra" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" FontFamily="Exo 2"/>
                    </StackPanel>
                </Border>

                <Border Width="347" Height="192" Margin="30 0 0 0" BorderBrush="#FF33FFFF" BorderThickness="0.42" Background="#1A1C24" CornerRadius="15">
                    <StackPanel Margin="30">
                        <TextBlock Text="ПРИБЫЛЬ (24ч)" FontSize="18" Foreground="#6E7485" FontFamily="Exo 2"/>
                        <TextBlock Text="$151,521" FontSize="36" Margin="0 20 0 15" FontWeight="Bold" Foreground="#FFFFFF" FontFamily="Exo 2"/>
                        <TextBlock Text="+15% к вчера" FontSize="18" FontWeight="SemiBold" Foreground="#00FFC2" FontFamily="Exo 2"/>
                    </StackPanel>
                </Border>

                <Border Width="339" Height="192" Margin="30 0 0 0" BorderBrush="#FF33FFFF" BorderThickness="0.42" Background="#1A1C24" CornerRadius="15">
                    <StackPanel Margin="30">
                        <TextBlock Text="ПРИБЫЛЬ (Сеанс)" FontSize="18" Foreground="#6E7485" FontFamily="Exo 2"/>
                        <TextBlock Text="$38,151" FontSize="36" Margin="0 20 0 15" FontWeight="Bold" Foreground="#FFFFFF" FontFamily="Exo 2"/>
                        <TextBlock Text="-45% от сеанса" FontSize="18" FontWeight="SemiBold" Foreground="#FF4D4D" FontFamily="Exo 2"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Width="1470" Height="350" BorderBrush="#FF33FFFF" BorderThickness="0.42" Background="#1A1C24" CornerRadius="15" HorizontalAlignment="Left">
                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="> ПОСЛЕДНИЕ СОБЫТИЯ" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,15" FontFamily="Exo 2"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="LogsContainer">
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="10:42:04" Foreground="#44FFFFFF" FontSize="18" FontFamily="Exo 2"/>
                                <TextBlock Grid.Column="1" Text="Успешная покупка" Foreground="White" FontSize="18" Margin="20,0,0,0" FontFamily="Exo 2"/>
                                <TextBlock Grid.Column="2" Text="-2,500" Foreground="#FF4B4B" FontSize="18" FontWeight="Bold" FontFamily="Exo 2"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Page>